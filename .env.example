APP_VERSION=1.4.3

# Public ports
PROXY_PORT=9090
API_PORT=9091

# Upstream LLM service base URL.
# Important: use the service base URL only. Do not append /v1 here,
# because the proxy already forwards client request paths like /v1/chat/completions.
UPSTREAM_URL=http://your-llm-service:8080

# Admin hash used by dashboard/API for full access.
# Value format: SHA-256(api_key) first 32 hex chars.
# Example:
# python3 - <<'PY'
# import hashlib
# print(hashlib.sha256(b'your-api-key').hexdigest()[:32])
# PY
ADMIN_KEY_HASH=

# Optional legacy admin bearer key. Prefer ADMIN_KEY_HASH for new deployments.
DASHBOARD_API_KEY=

# Runtime settings
LOG_LEVEL=INFO
ANALYZER_INTERVAL=5
ANALYZER_BATCH_SIZE=100

# Dev reverse proxy host
TRAEFIK_HOST=llm2.snow13.top
