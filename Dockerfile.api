FROM python:3.12-slim
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/
WORKDIR /app
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project
COPY api/ ./api/
COPY analyzer/ ./analyzer/
ENV PATH="/app/.venv/bin:$PATH" ANALYTICS_DB=/data/analytics/analytics.db RAW_DB=/data/logs/raw.db BODIES_DIR=/data/logs/bodies
EXPOSE 9091
CMD ["uvicorn", "api.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "9091"]
